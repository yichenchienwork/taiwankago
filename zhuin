        btn.id = `robot-v-${key}`;
        vowBox.appendChild(btn);
      });
      selectRobotTone('', '第一声');
    }

    function selectRobotConsonant(symbol) {
      robotSelectedConsonant = symbol;
      document.querySelectorAll("[id^='robot-c-']").forEach(el => el.classList.remove("bg-cyan-500", "text-white", "border-cyan-600"));
      const targetId = symbol ? `robot-c-${symbol}` : "robot-c-empty";
      document.getElementById(targetId).classList.add("bg-cyan-500", "text-white", "border-cyan-600");
      updateRobotPreview();
    }

    function selectRobotVowel(symbol) {
      robotSelectedVowel = symbol;
      document.querySelectorAll("[id^='robot-v-']").forEach(el => el.classList.remove("bg-emerald-500", "text-white", "border-emerald-600"));
      document.getElementById(`robot-v-${symbol}`).classList.add("bg-emerald-500", "text-white", "border-emerald-600");
      updateRobotPreview();
    }

    function selectRobotTone(mark, name) {
      robotSelectedToneMark = mark;
      robotSelectedToneName = name;
      document.querySelectorAll("[id^='tone-r-']").forEach(el => el.classList.remove("bg-rose-500", "text-white", "border-rose-600"));
      const targetId = mark ? `tone-r-${mark}` : "tone-r-";
      document.getElementById(targetId).classList.add("bg-rose-500", "text-white", "border-rose-600");
      updateRobotPreview();
    }

    // Toggle validation and display cross for invalid Chinese combinations
    function updateRobotPreview() {
      const isValid = isValidCombination(robotSelectedConsonant, robotSelectedVowel);
      const previewStr = (robotSelectedConsonant || "") + (robotSelectedVowel || "—") + (robotSelectedToneMark || "");
      
      const previewEl = document.getElementById("preview-display-string");
      const playBtn = document.getElementById("robot-play-btn");
      const toneNameEl = document.getElementById("preview-display-tone-name");
      
      if (!isValid && robotSelectedVowel) {
        // Invalid combination: Render red cross "❌" and disable play controls
        previewEl.innerHTML = `<span class="text-rose-500 flex items-center gap-1">❌ <span class="text-stone-400 text-lg line-through">${previewStr}</span></span>`;
        toneNameEl.innerText = "不成立の組み合わせ";
        toneNameEl.className = "text-[10px] font-bold text-rose-500";
        playBtn.disabled = true;
        playBtn.className = "bg-stone-300 text-stone-500 w-10 h-10 rounded-lg flex items-center justify-center cursor-not-allowed transition opacity-50";
      } else {
        previewEl.innerText = previewStr;
        toneNameEl.innerText = robotSelectedToneName;
        toneNameEl.className = "text-[10px] font-medium text-stone-400";
        playBtn.disabled = false;
        playBtn.className = "bg-amber-500 hover:bg-amber-600 active:scale-95 text-stone-900 w-10 h-10 rounded-lg flex items-center justify-center transition shadow-md";
      }
    }

    function triggerRobotVoiceSynthesis() {
      if (!robotSelectedVowel) {
        return;
      }
      
      let textToSpeak = "";
      const baseCombined = (robotSelectedConsonant || "") + robotSelectedVowel;

      const explicitMapping = {
        "ㄅㄚ": "八", "ㄅㄚˊ": "拔", "ㄅㄚˇ": "把", "ㄅㄚˋ": "爸", "ㄅㄛ": "波", "ㄅㄛˊ": "博", "ㄅㄛˇ": "跛", "ㄅㄛˋ": "擘",
        "ㄇㄚ": "媽", "ㄇㄚˊ": "麻", "ㄇㄚˇ": "馬", "ㄇㄚˋ": "罵", "ㄇㄧ": "咪", "ㄇㄧˊ": "迷", "ㄇㄧˇ": "米", "ㄇㄧˋ": "密",
        "ㄌㄚ": "拉", "ㄌㄚˊ": "藍", "ㄌㄚˇ": "喇", "ㄌㄚˋ": "辣", "ㄌㄧ": "哩", "ㄌㄧˊ": "梨", "ㄌㄧˇ": "鯉", "ㄌㄧˋ": "利",
        "ㄧㄚ": "鴨", "ㄧㄚˊ": "牙", "ㄧㄚˇ": "雅", "ㄧㄚˋ": "亞", "ㄨㄛ": "窩", "ㄨㄛˊ": "駝", "ㄨㄛˇ": "我", "ㄨㄛˋ": "握"
      };

      const lookupKey = baseCombined + robotSelectedToneMark;
      if (explicitMapping[lookupKey]) {
        textToSpeak = explicitMapping[lookupKey];
      } else {
        textToSpeak = baseCombined;
      }

      if ('speechSynthesis' in window) {
        window.speechSynthesis.cancel();
        const utterance = new SpeechSynthesisUtterance(textToSpeak);
        if (speechVoice) utterance.voice = speechVoice;
        utterance.lang = 'zh-TW';
        utterance.rate = 0.75;
        
        if (robotSelectedToneMark === 'ˋ') utterance.pitch = 0.9;
        if (robotSelectedToneMark === 'ˊ') utterance.pitch = 1.1;

        window.speechSynthesis.speak(utterance);
      }
    }
  </script>
</body>
