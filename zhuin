    function nextQuizTurn() {
      document.getElementById("quiz-question-index").innerText = `${quizCurrentQuestion} / 10`;
      const randomIndex = Math.floor(Math.random() * quizSymbolsList.length);
      quizTargetSymbol = quizSymbolsList[randomIndex];
      
      currentQuizChoices = [quizTargetSymbol];
      while (currentQuizChoices.length < 4) {
        const dist = quizSymbolsList[Math.floor(Math.random() * quizSymbolsList.length)];
        if (!currentQuizChoices.includes(dist)) currentQuizChoices.push(dist);
      }
      currentQuizChoices.sort(() => Math.random() - 0.5);

      for (let i = 0; i < 4; i++) {
        const btn = document.getElementById(`choice-${i}`);
        btn.innerText = currentQuizChoices[i];
