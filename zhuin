<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>台湾注音符号（ボポモフォ）学習アプリ</title>
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;900&family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    body {
      font-family: 'Noto Sans JP', sans-serif;
      background-color: #fcfbf7;
    }
    .serif-title {
      font-family: 'Noto Serif TC', serif;
    }
    .dashed-box {
      border: 2px dashed #f59e0b;
    }
    #canvas {
      cursor: crosshair;
      touch-action: none;
    }
    .writing-vertical {
      writing-mode: vertical-rl;
      text-orientation: mixed;
    }
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-6px); }
      75% { transform: translateX(6px); }
    }
    .animate-shake {
      animation: shake 0.2s ease-in-out infinite;
      animation-iteration-count: 2;
    }
    .tab-active {
      background-color: #b45309;
      color: white;
    }
    /* Print optimizations (Forces perfect A4 landscape sheet fit) */
    @media print {
      @page {
        size: A4 landscape;
        margin: 0.3cm;
      }
      body {
        background-color: white !important;
        padding: 0 !important;
        margin: 0 !important;
      }
      .no-print {
        display: none !important;
      }
      .print-container {
        width: 100% !important;
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
        transform: scale(0.78);
        transform-origin: top center;
      }
      main, section {
        box-shadow: none !important;
        border: 1px solid #e5e7eb !important;
        page-break-inside: avoid;
        background-color: white !important;
      }
    }
  </style>
</head>
<body class="min-h-screen text-slate-800 p-3 md:p-8 flex flex-col justify-between">

  <div class="print-container max-w-7xl mx-auto w-full">
    <!-- Header & App Navigation Bar -->
    <header class="no-print w-full mb-6 bg-white/80 backdrop-blur border border-stone-200/60 p-4 rounded-2xl shadow-sm flex flex-col lg:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-amber-500 rounded-xl flex items-center justify-center text-white font-black text-xl">
          ㄅ
        </div>
        <div>
          <h1 class="text-xl font-bold tracking-wider serif-title text-stone-800">台湾注音符号（ボポモフォ）総合学習システム</h1>
        </div>
      </div>

      <!-- Main Navigation Tabs -->
      <div class="bg-stone-100 p-1 rounded-xl flex items-center gap-1 text-sm font-medium">
        <button onclick="switchTab('chart-page')" id="tab-chart-page" class="px-4 py-2 rounded-lg transition-all tab-active shadow-sm flex items-center gap-1.5">
          <i data-lucide="grid" class="w-4 h-4"></i>
          <span>注音符号表</span>
        </button>
        <button onclick="switchTab('robot-page')" id="tab-robot-page" class="px-4 py-2 rounded-lg transition-all text-stone-500 hover:text-stone-800 flex items-center gap-1.5">
          <i data-lucide="cpu" class="w-4 h-4"></i>
          <span>発音ロボット</span>
        </button>
      </div>

      <!-- Controls and Toolbar -->
      <div class="flex flex-wrap items-center gap-2">
        <div class="bg-stone-100 p-1 rounded-xl flex items-center gap-1 text-xs font-semibold">
          <button onclick="changeMode('standard')" id="btn-standard" class="px-3 py-1.5 rounded-lg bg-white text-stone-800 shadow-sm">標準</button>
          <button onclick="changeMode('pinyin')" id="btn-pinyin" class="px-3 py-1.5 rounded-lg text-stone-500 hover:text-stone-800">ピンイン</button>
        </div>

        <button onclick="startQuiz()" class="bg-amber-500 hover:bg-amber-600 text-white font-medium text-xs px-3 py-2 rounded-xl flex items-center gap-1.5 transition shadow-sm">
          <i data-lucide="gamepad-2" class="w-3.5 h-3.5"></i>
          <span>発音テスト</span>
        </button>

        <button onclick="window.print()" class="border border-stone-300 hover:bg-stone-50 text-stone-600 font-medium text-xs px-3 py-2 rounded-xl flex items-center gap-1.5 transition">
          <i data-lucide="printer" class="w-3.5 h-3.5"></i>
          <span>印刷する</span>
        </button>
      </div>
    </header>

    <!-- PAGE 1: CORE CHART & COMBINED RIMES VIEW -->
    <div id="page-chart-content" class="tab-content-block">
      <!-- Main Layout Box (DESKTOP: Side-by-side R-to-L Grid view) -->
      <main class="hidden md:block w-full bg-amber-50/10 border-2 border-amber-600/30 rounded-3xl p-6 shadow-md print-shadow-none bg-white">
        <div class="grid grid-cols-11 gap-6 items-stretch">
          
          <!-- LEFT BLOCK: 韻符 (母音) - 5 Columns -->
          <div class="col-span-5 border-r-2 border-stone-200/80 pr-4 flex gap-4">
            <div class="flex-1 grid grid-cols-5 gap-2" id="grid-yunfu-desktop">
              <!-- Instantiated via Javascript -->
            </div>
            <div class="flex flex-col justify-center items-center text-emerald-700 font-black px-1 shrink-0">
              <span class="writing-vertical text-md tracking-widest serif-title border border-emerald-100 bg-emerald-50/50 py-4 px-1.5 rounded-xl">母音</span>
            </div>
          </div>

          <!-- RIGHT BLOCK: 聲符 (子音) - 6 Columns -->
          <div class="col-span-6 flex gap-4">
            <div class="flex-1 grid grid-cols-6 gap-2" id="grid-shengfu-desktop">
              <!-- Instantiated via Javascript -->
            </div>
            <div class="flex flex-col justify-center items-center text-cyan-700 font-black px-1 shrink-0">
              <span class="writing-vertical text-md tracking-widest serif-title border border-cyan-100 bg-cyan-50/50 py-4 px-1.5 rounded-xl">子音</span>
            </div>
          </div>

        </div>
      </main>

      <!-- MOBILE ONLY: Beautiful portrait grid layout with zero horizontal scrolls -->
      <main class="block md:hidden w-full bg-white border border-stone-200 rounded-2xl p-4 shadow-sm space-y-6">
        <!-- 1. Consonants Section (子音) -->
        <div>
          <h3 class="text-xs font-black text-cyan-700 mb-3 tracking-widest border-b border-cyan-100 pb-1 flex justify-between items-center">
            <span>子音 (声母)</span>
            <span class="text-[10px] text-stone-400 font-normal">21音</span>
          </h3>
          <div class="grid grid-cols-4 gap-2" id="grid-shengfu-mobile">
            <!-- Populated via JS -->
          </div>
        </div>

        <!-- 2. Vowels Section (母音) -->
        <div>
          <h3 class="text-xs font-black text-emerald-700 mb-3 tracking-widest border-b border-emerald-100 pb-1 flex justify-between items-center">
            <span>母音 (韻母)</span>
            <span class="text-[10px] text-stone-400 font-normal">16音</span>
          </h3>
          <div class="grid grid-cols-4 gap-2" id="grid-yunfu-mobile">
            <!-- Populated via JS -->
          </div>
        </div>
      </main>

      <!-- BOTTOM BLOCK: 結合母音專區 -->
      <section class="mt-6 w-full bg-white border-2 border-amber-600/20 rounded-3xl p-4 md:p-8 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-7 h-7 bg-rose-500 rounded-lg flex items-center justify-center text-white font-bold text-xs">合</span>
          <div>
            <h3 class="text-md font-bold tracking-wider serif-title text-stone-800">結合母音 (介音と母音の組み合わせ)</h3>
            <p class="text-[11px] text-stone-500">介音「ㄧ, ㄨ, ㄩ」から始まる複母音記号です。</p>
          </div>
        </div>

        <!-- Desktop combined grid (11 columns) -->
        <div id="grid-combined-rimes-desktop" class="hidden md:grid grid-cols-11 gap-2.5">
          <!-- Populated via JS -->
        </div>

        <!-- Mobile combined grid (4 columns) -->
        <div id="grid-combined-rimes-mobile" class="grid md:hidden grid-cols-4 gap-2">
          <!-- Populated via JS -->
        </div>
      </section>

      <!-- TONES EXPLANATION BLOCK -->
      <section class="mt-6 w-full bg-stone-50 border border-stone-200/60 rounded-3xl p-5 shadow-sm">
        <div class="flex items-center gap-2 mb-3 text-stone-700">
          <i data-lucide="music" class="w-4 h-4 text-amber-500"></i>
          <h3 class="text-sm font-bold tracking-wider">【 華語の4つの声調（四声・アクセント）について 】</h3>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-5 gap-3 text-xs">
          <div class="bg-white p-3 rounded-xl border border-stone-200 shadow-xs">
            <span class="font-bold text-stone-800 block mb-1 text-center bg-stone-100 py-1 rounded-md">第一声（高平調）</span>
            <p class="text-stone-500 mb-1"><strong>表記：</strong>記号なし (例：ㄚ)</p>
            <p class="text-stone-600">高くて平らな音。ドレミの「ソ」をキープするように真っ直ぐ長く発音します。</p>
          </div>
          <div class="bg-white p-3 rounded-xl border border-stone-200 shadow-xs">
            <span class="font-bold text-amber-700 block mb-1 text-center bg-amber-50 py-1 rounded-md">第二声（高昇調）</span>
            <p class="text-stone-500 mb-1"><strong>表記：</strong>右上へ「 ˊ 」 (例：ㄚˊ)</p>
            <p class="text-stone-600">下から上へ一気に引き上げる音。日本語で「ええ！？」と驚くときのような響きです。</p>
          </div>
          <div class="bg-white p-3 rounded-xl border border-stone-200 shadow-xs">
            <span class="font-bold text-emerald-700 block mb-1 text-center bg-emerald-50 py-1 rounded-md">第三声（低降調）</span>
            <p class="text-stone-500 mb-1"><strong>表記：</strong>V字「 ˇ 」 (例：ㄚˇ)</p>
            <p class="text-stone-600">一番低いところまで声をグッと落とす音。低く抑えるようにため息混じりで出します。</p>
          </div>
          <div class="bg-white p-3 rounded-xl border border-stone-200 shadow-xs">
            <span class="font-bold text-rose-700 block mb-1 text-center bg-rose-50 py-1 rounded-md">第四声（全降調）</span>
            <p class="text-stone-500 mb-1"><strong>表記：</strong>右下へ「 ˋ 」 (例：ㄚˋ)</p>
            <p class="text-stone-600">上から下へカラスの鳴き声のように鋭く投げ下ろす音。「アッ」と短く強く落とします。</p>
          </div>
          <div class="bg-white p-3 rounded-xl border border-stone-200 shadow-xs">
            <span class="font-bold text-cyan-700 block mb-1 text-center bg-cyan-50 py-1 rounded-md">軽声（短低調）</span>
            <p class="text-stone-500 mb-1"><strong>表記：</strong>頭に丸点「 ˙ 」 (例：˙ㄚ)</p>
            <p class="text-stone-600">軽く短く添える音。前の音の勢いに任せて、力を抜いてポンと置くように発音します。</p>
          </div>
        </div>
      </section>
    </div>

    <!-- PAGE 2: SPEECH ROBOT INTERACTIVE ROBOT SYSTEM -->
    <div id="page-robot-content" class="tab-content-block hidden no-print">
      <div class="w-full bg-white border-2 border-stone-200 rounded-3xl p-4 md:p-6 shadow-sm max-w-4xl mx-auto">
        <div class="flex items-center gap-3 border-b border-stone-100 pb-4 mb-6">
          <div class="w-10 h-10 bg-stone-800 rounded-xl flex items-center justify-center text-white">
            <i data-lucide="cpu" class="w-5 h-5"></i>
          </div>
          <div>
            <h2 class="text-lg font-bold text-stone-800">注音拼音ロボット (発音メカ)</h2>
            <p class="text-xs text-stone-400">子音、母音、声調をそれぞれ自由に選択して組み合わせて、華語の結合音システムを発音させましょう！</p>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Selector column 1: 子音 -->
          <div class="bg-cyan-50/30 border border-cyan-100 p-3 md:p-4 rounded-2xl">
            <h3 class="text-xs font-bold text-cyan-800 mb-2 flex justify-between"><span>1. 子音 (声母) を選ぶ</span><span class="text-stone-400 font-normal">任意</span></h3>
            <div id="robot-consonants" class="grid grid-cols-4 gap-1.5 max-h-[220px] overflow-y-auto p-1 bg-white border border-stone-100 rounded-xl"></div>
          </div>

          <!-- Selector column 2: 母音/結合母音 -->
          <div class="bg-emerald-50/30 border border-emerald-100 p-3 md:p-4 rounded-2xl">
            <h3 class="text-xs font-bold text-emerald-800 mb-2 flex justify-between"><span>2. 母音 / 結合音を選ぶ</span><span class="text-amber-600 font-bold">必須 *</span></h3>
            <div id="robot-vowels" class="grid grid-cols-3 gap-1.5 max-h-[220px] overflow-y-auto p-1 bg-white border border-stone-100 rounded-xl"></div>
          </div>

          <!-- Selector column 3: 聲調 -->
          <div class="bg-rose-50/30 border border-rose-100 p-3 md:p-4 rounded-2xl flex flex-col justify-between">
            <div>
              <h3 class="text-xs font-bold text-rose-800 mb-2">3. 声調 (アクセント)</h3>
              <div id="robot-tones" class="space-y-1.5 p-1 bg-white border border-stone-100 rounded-xl">
                <button onclick="selectRobotTone('', '第一声')" id="tone-r-" class="w-full text-left text-xs font-semibold px-3 py-2 rounded-lg border border-stone-200 hover:bg-stone-50 transition flex justify-between"><span>第一声 (高平)</span><span class="text-stone-400">記号なし</span></button>
                <button onclick="selectRobotTone('ˊ', '第二声')" id="tone-r-ˊ" class="w-full text-left text-xs font-semibold px-3 py-2 rounded-lg border border-stone-200 hover:bg-stone-50 transition flex justify-between"><span>第二声 (高昇)</span><span class="text-amber-600">ˊ</span></button>
                <button onclick="selectRobotTone('ˇ', '第三声')" id="tone-r-ˇ" class="w-full text-left text-xs font-semibold px-3 py-2 rounded-lg border border-stone-200 hover:bg-stone-50 transition flex justify-between"><span>第三声 (低降)</span><span class="text-emerald-600">ˇ</span></button>
                <button onclick="selectRobotTone('ˋ', '第四声')" id="tone-r-ˋ" class="w-full text-left text-xs font-semibold px-3 py-2 rounded-lg border border-stone-200 hover:bg-stone-50 transition flex justify-between"><span>第四声 (全降)</span><span class="text-rose-600">ˋ</span></button>
                <button onclick="selectRobotTone('˙', '軽声')" id="tone-r-˙" class="w-full text-left text-xs font-semibold px-3 py-2 rounded-lg border border-stone-200 hover:bg-stone-50 transition flex justify-between"><span>軽声 (短低)</span><span class="text-cyan-600">˙</span></button>
              </div>
            </div>

            <!-- Total Preview & Trigger Action Button -->
            <div class="mt-4 pt-3 border-t border-stone-200/60">
              <span class="text-[10px] uppercase tracking-wider font-bold text-stone-400 block mb-1">現在の組み立てスロット</span>
              <div class="bg-stone-900 text-white rounded-xl p-3 flex items-center justify-between shadow-inner">
                <div class="flex items-baseline gap-1">
                  <span id="preview-display-string" class="text-2xl font-black tracking-wider text-amber-400 serif-title">—</span>
                  <span id="preview-display-tone-name" class="text-[10px] font-medium text-stone-400">アクセント未選</span>
                </div>
                <button id="robot-play-btn" onclick="triggerRobotVoiceSynthesis()" class="bg-amber-500 hover:bg-amber-600 active:scale-95 text-stone-900 w-10 h-10 rounded-lg flex items-center justify-center transition shadow-md">
                  <i data-lucide="play" class="w-5 h-5 fill-stone-900"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="no-print text-center text-xs text-stone-400 mt-8 mb-4 max-w-7xl mx-auto w-full flex flex-col gap-1">
    <p>© 台湾注音符号学習ツール · 華語（繁體字）学習用教材 · Papago準拠ピンイン対照 · 外部教材連携：<a href="https://kidsvideo1.hle.com.tw/1/" target="_blank" class="underline hover:text-amber-600 font-bold">翰林注音符號發音網</a></p>
    <p class="font-semibold text-stone-500 mt-1">設計製作：簡翊真</p>
  </footer>

  <!-- INTERACTIVE POPUP MODAL -->
  <div id="detail-modal" class="no-print hidden fixed inset-0 bg-stone-900/60 backdrop-blur-sm flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-3xl max-w-2xl w-full p-5 md:p-6 shadow-2xl border border-stone-100 flex flex-col gap-5 animate-in fade-in zoom-in duration-150">
      
      <div class="flex justify-between items-start">
        <div class="flex items-center gap-4">
          <div id="modal-accent-bg" class="w-14 h-14 rounded-xl flex items-center justify-center text-2xl font-black text-white">
            <span id="modal-char" class="serif-title">ㄅ</span>
          </div>
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <h2 id="modal-title" class="text-xl font-bold text-stone-800">注音符号 ㄅ</h2>
              <div class="flex items-center gap-1">
                <button onclick="speakCurrentSymbol(0.75)" class="p-1.5 bg-amber-100 hover:bg-amber-200 text-amber-800 rounded-lg transition flex items-center gap-1 text-xs font-semibold">
                  <i data-lucide="volume-2" class="w-3.5 h-3.5"></i><span>再生</span>
                </button>
                <button onclick="speakCurrentSymbol(0.5)" class="p-1.5 bg-stone-100 hover:bg-stone-200 text-stone-600 rounded-lg transition flex items-center gap-1 text-xs">
                  <i data-lucide="turtle" class="w-3.5 h-3.5"></i><span>スロー</span>
                </button>
                <a id="modal-hle-link" href="https://kidsvideo1.hle.com.tw/1/" target="_blank" class="p-1.5 bg-rose-100 hover:bg-rose-200 text-rose-800 rounded-lg transition flex items-center gap-1 text-xs font-semibold">
                  <i data-lucide="external-link" class="w-3.5 h-3.5"></i><span>發音教材</span>
                </a>
              </div>
            </div>
            <p class="text-xs text-stone-400 mt-0.5">ピンイン：<span id="modal-pinyin" class="font-bold text-stone-600">—</span> | グループ：<span id="modal-type" class="font-medium text-stone-600">—</span></p>
          </div>
        </div>
        <button onclick="closeModal()" class="text-stone-400 hover:text-stone-600 p-1 rounded-lg hover:bg-stone-50 transition">
          <i data-lucide="x" class="w-5 h-5"></i>
        </button>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div class="flex flex-col gap-2">
          <div class="flex justify-between items-center text-xs text-stone-500">
            <span class="font-bold flex items-center gap-1"><i data-lucide="pen-tool" class="w-3.5 h-3.5"></i><span>なぞり書き練習 (九宮格)</span></span>
            <button onclick="clearCanvas()" class="text-amber-700 font-bold flex items-center gap-0.5"><i data-lucide="eraser" class="w-3 h-3"></i><span>リセット</span></button>
          </div>
          <div class="relative w-full aspect-square border-2 border-amber-500/20 rounded-2xl overflow-hidden bg-white flex items-center justify-center">
            <!-- Perfectly centered canvas guide word container -->
            <div id="canvas-guide" class="absolute inset-0 flex items-center justify-center text-[190px] font-black text-stone-200/50 select-none serif-title pointer-events-none z-0">ㄅ</div>
            <canvas id="canvas" class="absolute inset-0 w-full h-full z-10"></canvas>
          </div>
        </div>

        <div class="flex flex-col justify-between bg-stone-50 p-4 rounded-2xl border border-stone-200/60 max-h-[300px] overflow-y-auto">
          <div>
            <h3 class="text-xs font-bold text-stone-400 tracking-wider mb-1.5">【 発音のアドバイス 】</h3>
            <div class="mb-2">
              <span class="text-[10px] font-semibold text-stone-400 block mb-0.5">日本語の近似音：</span>
              <span id="modal-kana" class="text-xs font-bold text-amber-800 bg-amber-50 px-2 py-0.5 rounded-lg border border-amber-200/60 inline-block">—</span>
            </div>
            <p class="text-xs text-stone-600 leading-relaxed"><strong class="text-stone-800">コツ：</strong> <span id="modal-tip">—</span></p>
          </div>

          <div class="border-t border-stone-200 pt-3 mt-3">
            <h4 class="text-xs font-bold text-stone-400 mb-1.5">代表的な単語の例</h4>
            <div class="flex items-center gap-2 bg-white border border-stone-200 p-2.5 rounded-xl shadow-xs">
              <button onclick="speakExampleWord()" class="w-7 h-7 rounded-full bg-amber-100 hover:bg-amber-200 text-amber-800 flex items-center justify-center transition shrink-0">
                <i data-lucide="volume-2" class="w-3.5 h-3.5"></i>
              </button>
              <p id="modal-example" class="text-xs font-bold text-stone-700 leading-normal">—</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- FIXED 10-QUESTION PROGRESSIVE QUIZ SCREEN OVERLAY -->
  <div id="quiz-screen" class="no-print hidden fixed inset-0 bg-stone-50 z-50 flex flex-col justify-between p-4 md:p-6">
    <div class="flex justify-between items-center max-w-2xl mx-auto w-full border-b border-stone-200 pb-3">
      <div class="flex items-center gap-2">
        <span class="w-7 h-7 bg-amber-500 rounded-lg flex items-center justify-center text-white text-xs font-bold">Q</span>
        <h2 class="text-sm font-bold text-stone-800">注音聞き取りテスト (<span id="quiz-question-index" class="text-amber-700 font-black">1 / 10</span> 題)</h2>
      </div>
      <div class="flex items-center gap-4 text-xs">
        <span class="font-semibold text-stone-500">現在のスコア: <span id="quiz-screen-score" class="text-amber-600 font-bold">0</span></span>
