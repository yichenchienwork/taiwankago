    function submitQuizAnswer(index) {
      const chosen = currentQuizChoices[index];
      const btn = document.getElementById(`choice-${index}`);
      const fb = document.getElementById("quiz-feedback-text");

      if (chosen === quizTargetSymbol) {
        quizScore += 10;
        document.getElementById("quiz-screen-score").innerText = quizScore;
        btn.className = "aspect-[2.2/1] rounded-xl border border-emerald-500 bg-emerald-50 text-emerald-800 text-2xl font-bold flex items-center justify-center ring-4 ring-emerald-200 scale-102 transition";
