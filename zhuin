    // Accurate Phonetic validator helper for Mandarin syllables
    function isValidCombination(c, v) {
      if (!v) return true; 
      if (!c) return true; // Standalone vowel is always valid

      // ㄐ, ㄑ, ㄒ can ONLY combine with ㄧ, ㄩ or combined rimes starting with ㄧ, ㄩ
      if (["ㄐ", "ㄑ", "ㄒ"].includes(c)) {
        return v === "ㄧ" || v === "ㄩ" || v.startsWith("ㄧ") || v.startsWith("ㄩ");
      }

      // ㄅ, ㄆ, ㄇ, ㄈ rules
      if (["ㄅ", "ㄆ", "ㄇ", "ㄈ"].includes(c)) {
        if (v === "ㄨ") return true;
        if (v.startsWith("ㄨ") || v.startsWith("ㄩ") || v === "ㄩ") return false;
        if (c === "ㄈ") {
          return ["ㄚ", "ㄛ", "ㄟ", "ㄡ", "ㄢ", "ㄣ", "ㄤ", "ㄥ", "ㄨ"].includes(v);
        }
        if (v.startsWith("ㄧ")) {
          return ["ㄧ", "ㄧㄝ", "ㄧㄠ", "ㄧㄢ", "ㄧㄣ", "ㄧㄥ"].includes(v);
        }
        return ["ㄚ", "ㄛ", "ㄞ", "ㄟ", "ㄠ", "ㄡ", "ㄢ", "ㄣ", "ㄤ", "ㄥ"].includes(v) || (c === "ㄇ" && v === "ㄜ");
      }

      // ㄍ, ㄎ, ㄏ rules
      if (["ㄍ", "ㄎ", "ㄏ"].includes(c)) {
        if (v === "ㄧ" || v.startsWith("ㄧ") || v === "ㄩ" || v.startsWith("ㄩ")) return false;
        if (v === "ㄛ") return false;
        return true;
      }

      // ㄓ, ㄔ, ㄕ, ㄖ, ㄗ, ㄘ, ㄙ rules
      if (["ㄓ", "ㄔ", "ㄕ", "ㄖ", "ㄗ", "ㄘ", "ㄙ"].includes(c)) {
        if (v === "ㄧ" || v.startsWith("ㄧ") || v === "ㄩ" || v.startsWith("ㄩ")) return false;
        if (v === "ㄛ") return false;
        if (c === "ㄖ" && ["ㄞ", "ㄟ", "ㄤ"].includes(v)) return false;
        return true;
      }

      // ㄉ, ㄊ, ㄋ, ㄌ rules
      if (["ㄉ", "ㄊ"].includes(c)) {
        if (v === "ㄩ" || v.startsWith("ㄩ") || v === "ㄨㄥ") return false;
        if (v.startsWith("ㄨ") && !["ㄨ", "ㄨㄚ", "ㄨㄛ", "ㄨㄞ", "ㄨㄟ", "ㄨㄢ", "ㄨㄣ"].includes(v)) return false;
        if (v.startsWith("ㄧ") && !["ㄧ", "ㄧㄝ", "ㄧㄠ", "ㄧㄡ", "ㄧㄢ", "ㄧㄥ"].includes(v)) return false;
        if (v === "ㄛ") return false;
        return true;
      }

      if (["ㄋ", "ㄌ"].includes(c)) {
        if (v === "ㄛ") return false;
        return true;
      }

      return true;
    }

